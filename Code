import tkinter as tk
from tkinter import messagebox, ttk
import json
import os
from datetime import datetime

class WeatherDiary:
    def __init__(self, root):
        self.root = root
        self.root.title("Weather Diary (Дневник погоды)")
        self.root.geometry("600x500")
        self.data_file = "weather_data.json"
        self.entries = self.load_data()

        self.setup_ui()

    def setup_ui(self):
        # Панель ввода данных
        input_frame = tk.LabelFrame(self.root, text="Добавить новую запись", padx=10, pady=10)
        input_frame.pack(fill="x", padx=10, pady=5)

        tk.Label(input_frame, text="Дата (ДД.ММ.ГГГГ):").grid(row=0, column=0, sticky="w")
        self.date_entry = tk.Entry(input_frame)
        self.date_entry.insert(0, datetime.now().strftime("%d.%m.%Y"))
        self.date_entry.grid(row=0, column=1, padx=5, pady=2)

        tk.Label(input_frame, text="Температура (°C):").grid(row=1, column=0, sticky="w")
        self.temp_entry = tk.Entry(input_frame)
        self.temp_entry.grid(row=1, column=1, padx=5, pady=2)

        tk.Label(input_frame, text="Описание:").grid(row=2, column=0, sticky="w")
        self.desc_entry = tk.Entry(input_frame)
        self.desc_entry.grid(row=2, column=1, padx=5, pady=2, sticky="we")

        self.rain_var = tk.BooleanVar()
        tk.Checkbutton(input_frame, text="Осадки", variable=self.rain_var).grid(row=3, column=0, columnspan=2, sticky="w")

        btn_add = tk.Button(input_frame, text="Добавить запись", command=self.add_entry, bg="#4CAF50", fg="white")
        btn_add.grid(row=4, column=0, columnspan=2, pady=5, sticky="we")

        # Панель фильтрации
        filter_frame = tk.LabelFrame(self.root, text="Фильтрация", padx=10, pady=10)
        filter_frame.pack(fill="x", padx=10, pady=5)

        tk.Label(filter_frame, text="Мин. темп:").grid(row=0, column=0)
        self.filter_temp = tk.Entry(filter_frame, width=10)
        self.filter_temp.grid(row=0, column=1, padx=5)

        btn_filter = tk.Button(filter_frame, text="Применить фильтр", command=self.update_table)
        btn_filter.grid(row=0, column=2, padx=5)

        btn_reset = tk.Button(filter_frame, text="Сброс", command=self.reset_filter)
        btn_reset.grid(row=0, column=3, padx=5)

        # Таблица записей
        self.tree = ttk.Treeview(self.root, columns=("Date", "Temp", "Desc", "Rain"), show="headings")
        self.tree.heading("Date", text="Дата")
        self.tree.heading("Temp", text="Темп.")
        self.tree.heading("Desc", text="Описание")
        self.tree.heading("Rain", text="Осадки")
        self.tree.column("Temp", width=70)
        self.tree.column("Rain", width=70)
        self.tree.pack(fill="both", expand=True, padx=10, pady=10)

        self.update_table()

    def add_entry(self):
        date_str = self.date_entry.get().strip()
        temp_str = self.temp_entry.get().strip()
        desc_str = self.desc_entry.get().strip()
        has_rain = "Да" if self.rain_var.get() else "Нет"

        # Валидация
        try:
            datetime.strptime(date_str, "%d.%m.%Y")
        except ValueError:
            return messagebox.showerror("Ошибка", "Неверный формат даты! Используйте ДД.ММ.ГГГГ")

        try:
            temp_val = float(temp_str)
        except ValueError:
            return messagebox.showerror("Ошибка", "Температура должна быть числом!")

        if not desc_str:
            return messagebox.showerror("Ошибка", "Описание не может быть пустым!")

        # Сохранение
        new_entry = {
            "date": date_str,
            "temp": temp_val,
            "desc": desc_str,
            "rain": has_rain
        }
        self.entries.append(new_entry)
        if self.save_data():
            self.update_table()
            self.temp_entry.delete(0, tk.END)
            self.desc_entry.delete(0, tk.END)

    def update_table(self):
        # Очистка таблицы
        for item in self.tree.get_children():
            self.tree.delete(item)

        filter_val = self.filter_temp.get().strip()
        
        for entry in reversed(self.entries):
            # Фильтрация по температуре (если введено значение)
            try:
                if filter_val and entry['temp'] < float(filter_val):
                    continue
            except ValueError:
                pass # Если в фильтре не число, просто игнорируем его

            self.tree.insert("", tk.END, values=(entry['date'], f"{entry['temp']}°C", entry['desc'], entry['rain']))

    def reset_filter(self):
        self.filter_temp.delete(0, tk.END)
        self.update_table()

    def save_data(self):
        try:
            with open(self.data_file, 'w', encoding='utf-8') as f:
                json.dump(self.entries, f, ensure_ascii=False, indent=4)
            return True
        except Exception as e:
            messagebox.showerror("Ошибка записи", f"Не удалось сохранить данные: {e}")
            return False

    def load_data(self):
        if not os.path.exists(self.data_file):
            return []
        try:
            with open(self.data_file, 'r', encoding='utf-8') as f:
                return json.load(f)
        except Exception:
            return []

if __name__ == "__main__":
    root = tk.Tk()
    app = WeatherDiary(root)
    root.mainloop()
